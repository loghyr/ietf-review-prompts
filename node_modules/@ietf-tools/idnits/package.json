{
  "name": "@ietf-tools/idnits",
  "version": "3.0.0-alpha",
  "description": "Library / CLI to inspect Internet-Draft documents for a variety of conditions to conform with IETF policies.",
  "main": "lib/index.mjs",
  "type": "module",
  "scripts": {
    "upgrade-interactive": "ncu -i",
    "lint": "eslint",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ietf-tools/idnits.git"
  },
  "keywords": [
    "nits",
    "internet-drafts",
    "ietf"
  ],
  "author": "IETF Tools",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/ietf-tools/idnits/issues"
  },
  "homepage": "https://github.com/ietf-tools/idnits#readme",
  "private": false,
  "bin": {
    "idnits": "./cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "entities": "7.0.0",
    "fast-xml-parser": "5.2.5",
    "jschardet": "3.0.0",
    "listr2": "9.0.4",
    "lodash-es": "4.17.21",
    "luxon": "3.7.2",
    "semver": "7.7.2",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.36.0",
    "msw": "2.11.3",
    "neostandard": "0.12.2",
    "npm-check-updates": "19.0.0",
    "vitest": "3.2.4"
  },
  "files": [
    "cli.js",
    "lib"
  ]
